{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/contact-get-a-quote",
      "regex": "^/contact\\-get\\-a\\-quote(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact\\-get\\-a\\-quote(?:/)?$"
    },
    {
      "page": "/cookie-policy",
      "regex": "^/cookie\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/cookie\\-policy(?:/)?$"
    },
    {
      "page": "/faq",
      "regex": "^/faq(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/faq(?:/)?$"
    },
    {
      "page": "/gallery",
      "regex": "^/gallery(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/gallery(?:/)?$"
    },
    {
      "page": "/our-tents",
      "regex": "^/our\\-tents(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/our\\-tents(?:/)?$"
    },
    {
      "page": "/our-tents/custom-bespoke",
      "regex": "^/our\\-tents/custom\\-bespoke(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/our\\-tents/custom\\-bespoke(?:/)?$"
    },
    {
      "page": "/our-tents/sailcloth-silhouette",
      "regex": "^/our\\-tents/sailcloth\\-silhouette(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/our\\-tents/sailcloth\\-silhouette(?:/)?$"
    },
    {
      "page": "/our-tents/stretch-nomadic-bedouin",
      "regex": "^/our\\-tents/stretch\\-nomadic\\-bedouin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/our\\-tents/stretch\\-nomadic\\-bedouin(?:/)?$"
    },
    {
      "page": "/privacy-policy-2",
      "regex": "^/privacy\\-policy\\-2(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy\\-2(?:/)?$"
    },
    {
      "page": "/terms-conditions",
      "regex": "^/terms\\-conditions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms\\-conditions(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}